    {
      "parameters": {
        "jsCode": "const seen = new Set();\n\nreturn $items()\n  .map(i => i.json)\n  .filter(i => i && i.data && i.data.wuid)\n  .filter(i => {\n    let id = String(i.data.wuid)\n      .replace(\"@s.whatsapp.net\", \"\")\n      .replace(\"@c.us\", \"\")\n      .replace(/\\D/g, \"\");\n\n    if (id.startsWith(\"55\") && id.length === 13 && id[4] === \"9\") {\n      id = id.slice(0, 4) + id.slice(5);\n    }\n\n    if (seen.has(id)) return false;\n    seen.add(id);\n    return true;\n  })\n  .map(i => {\n    const data = i.data;\n\n    const originalRaw = (i.original_phone ?? data.original_phone ?? null);\n    const original_phone =\n      originalRaw === null || String(originalRaw).trim() === \"\"\n        ? null\n        : String(originalRaw).replace(/\\D/g, \"\");\n\n    const rowRaw = (i.row_number ?? data.row_number ?? null);\n    const row_number =\n      rowRaw === null || String(rowRaw).trim() === \"\"\n        ? null\n        : Number(rowRaw);\n\n    return {\n      json: {\n        wuid: data.wuid,\n        numberExists: data.numberExists,\n        razao: i.razao ?? data.razao ?? \"\",\n        cnpj: String(i.cnpj ?? data.cnpj ?? \"\"),\n        observacao: i.observacao ?? data.observacao ?? \"\",\n        ...(data.picture ? { picture: data.picture } : {}),\n        ...(data.status?.status ? { status: String(data.status.status).trim() } : {}),\n        ...(data.isBusiness !== undefined ? { isBusiness: data.isBusiness } : {}),\n        ...(original_phone ? { original_phone } : {}),\n        ...(row_number !== null && !Number.isNaN(row_number) ? { row_number } : {})\n      }\n    };\n  });"
      },
      "type": "n8n-nodes-base.code",
