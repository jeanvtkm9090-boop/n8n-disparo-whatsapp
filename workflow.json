    {
      "parameters": {
        "jsCode": "return $items().flatMap(item => {\n  const original = String(item.json.phone ?? \"\").replace(/\\D/g, \"\");\n\n  if (!original) {\n    return [{ json: { ...item.json, phone: \"\", original_phone: \"\" } }];\n  }\n\n  let country = \"\";\n  let number = original;\n\n  if (number.startsWith(\"55\")) {\n    country = \"55\";\n    number = number.slice(2);\n  }\n\n  const ddd = number.slice(0, 2);\n  let restante = number.slice(2);\n\n  let com9, sem9;\n  if (restante.startsWith(\"9\")) {\n    com9 = restante;\n    sem9 = restante.slice(1);\n  } else {\n    sem9 = restante;\n    com9 = \"9\" + restante;\n  }\n\n  const numeroCom9 = country + ddd + com9;\n  const numeroSem9 = country + ddd + sem9;\n\n  const numeros = [...new Set([original, numeroCom9, numeroSem9])];\n\n  return numeros.map(num => ({\n    json: { ...item.json, phone: num, original_phone: original }\n  }));\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1680, 1024],
      "id": "8ea43088-f68f-4492-86dc-64c9840970f5",
      "name": "Gera variações do número (com/sem 9)"
    },
